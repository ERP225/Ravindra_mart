# ---------------- Admin Login ----------------
@app.route("/admin_login", methods=["GET", "POST"])
def admin_login():
    if request.method == "POST":
        username = request.form["username"]
        password = request.form["password"]

        cursor.execute("SELECT * FROM admin WHERE username=%s", (username,))
        admin = cursor.fetchone()

        if admin and check_password_hash(admin['password'], password):
            session['admin'] = admin['id']
            return redirect("/admin_dashboard")
        else:
            flash("Invalid Credentials")

    return render_template("admin_login.html")


# ---------------- Admin Dashboard ----------------
@app.route("/admin_dashboard")
def admin_dashboard():
    if 'admin' not in session:
        return redirect("/admin_login")

    cursor.execute("SELECT * FROM products")
    products = cursor.fetchall()

    return render_template("admin_dashboard.html", products=products)


# ---------------- Add Product ----------------
@app.route("/add_product", methods=["POST"])
def add_product():
    if 'admin' not in session:
        return redirect("/admin_login")

    name = request.form["name"]
    price = request.form["price"]
    description = request.form["description"]
    quantity = request.form["quantity"]

    image = request.files["image"]
    filename = image.filename
    image.save(os.path.join(UPLOAD_FOLDER, filename))
    db_path = f"images/{filename}"  # relative path for static

    cursor.execute(
        "INSERT INTO products (name, price, description, image, quantity) VALUES (%s,%s,%s,%s,%s)",
        (name, price, description, db_path, quantity)
    )
    db.commit()

    flash(f"Product '{name}' added successfully!")
    return redirect("/admin_dashboard")


# ---------------- Delete Product ----------------
@app.route("/delete_product/<int:id>")
def delete_product(id):
    if 'admin' not in session:
        return redirect("/admin_login")

    cursor.execute("DELETE FROM products WHERE id=%s", (id,))
    db.commit()
    return redirect("/admin_dashboard")


# ---------------- User Register ----------------
@app.route("/register", methods=["GET", "POST"])
def register():
    if request.method == "POST":
        username = request.form["username"]
        password = generate_password_hash(request.form["password"], method="pbkdf2:sha256")

        cursor.execute(
            "INSERT INTO users (username, password) VALUES (%s,%s)",
            (username, password)
        )
        db.commit()

        return redirect("/user_login")
    return render_template("user_register.html")


# ---------------- User Login ----------------
@app.route("/user_login", methods=["GET", "POST"])
def user_login():
    if request.method == "POST":
        username = request.form["username"]
        password = request.form["password"]

        cursor.execute("SELECT * FROM users WHERE username=%s", (username,))
        user = cursor.fetchone()

        if user and check_password_hash(user['password'], password):
            session['user'] = user['id']
            return redirect("/user_dashboard")
        else:
            flash("Invalid Credentials")

    return render_template("user_login.html")


# ---------------- User Dashboard ----------------
@app.route("/user_dashboard")
def user_dashboard():
    if 'user' not in session:
        return redirect("/user_login")

    user_id = session['user']
    search = request.args.get("search")

    if search:
        cursor.execute("SELECT * FROM products WHERE name LIKE %s", ('%' + search + '%',))
    else:
        cursor.execute("SELECT * FROM products")

    products = cursor.fetchall()

    # cart count
    cursor.execute("SELECT SUM(quantity) AS cart_count FROM orders WHERE user_id=%s", (user_id,))
    cart_count = cursor.fetchone()['cart_count'] or 0

    # order count
    cursor.execute("SELECT COUNT(DISTINCT order_number) AS order_count FROM order_history WHERE user_id=%s", (user_id,))
    order_count = cursor.fetchone()['order_count'] or 0

    return render_template("user_dashboard.html",
                           products=products,
                           cart_count=cart_count,
                           order_count=order_count)


# ---------------- Add to Cart ----------------
@app.route("/add_to_cart/<int:product_id>", methods=["POST"])
def add_to_cart(product_id):
    if 'user' not in session:
        return jsonify({"error": "login required"}), 401

    user_id = session['user']
    qty = int(request.form["qty"])

    cursor.execute("SELECT quantity FROM products WHERE id=%s", (product_id,))
    product = cursor.fetchone()
    if not product or product['quantity'] < qty:
        return jsonify({"error": "Not enough stock"}), 400

    # update existing order or insert
    cursor.execute("SELECT id, quantity FROM orders WHERE user_id=%s AND product_id=%s", (user_id, product_id))
    order = cursor.fetchone()
    if order:
        cursor.execute("UPDATE orders SET quantity = quantity + %s WHERE id=%s", (qty, order['id']))
    else:
        cursor.execute("INSERT INTO orders (user_id, product_id, quantity) VALUES (%s,%s,%s)", (user_id, product_id, qty))

    cursor.execute("UPDATE products SET quantity = quantity - %s WHERE id=%s", (qty, product_id))
    db.commit()

    return jsonify({"success": True, "cart_count": get_cart_count(user_id)})


# ---------------- Cart ----------------
@app.route("/cart")
def cart():
    if 'user' not in session:
        return redirect("/user_login")

    user_id = session['user']
    cursor.execute("""
        SELECT o.id as order_id, p.name, p.image, p.price, o.quantity, p.quantity as stock
        FROM orders o
        JOIN products p ON o.product_id = p.id
        WHERE o.user_id = %s
    """, (user_id,))
    items = cursor.fetchall()

    total = sum(item['price'] * item['quantity'] for item in items)
    return render_template("cart.html", items=items, total=total)


@app.route("/cart_count")
def cart_count():
    if 'user' not in session:
        return jsonify({"count": 0})

    user_id = session['user']
    cursor.execute("SELECT SUM(quantity) AS cart_count FROM orders WHERE user_id=%s", (user_id,))
    count = cursor.fetchone()['cart_count'] or 0
    return jsonify({"count": count})


# ---------------- Remove / Update Cart ----------------
@app.route("/remove_item/<int:id>")
def remove_item(id):
    cursor.execute("DELETE FROM orders WHERE id=%s", (id,))
    db.commit()
    return redirect("/cart")


@app.route("/update_cart/<int:id>", methods=["POST"])
def update_cart(id):
    if 'user' not in session:
        return redirect("/user_login")

    new_qty = int(request.form["qty"])
    cursor.execute("SELECT product_id, quantity FROM orders WHERE id=%s", (id,))
    order = cursor.fetchone()
    if not order:
        return redirect("/cart")

    product_id = order['product_id']
    old_qty = order['quantity']

    cursor.execute("SELECT quantity FROM products WHERE id=%s", (product_id,))
    product = cursor.fetchone()
    stock_available = product['quantity'] + old_qty

    if new_qty > stock_available:
        flash(f"Cannot update. Only {stock_available} items available.")
        return redirect("/cart")

    cursor.execute("UPDATE orders SET quantity=%s WHERE id=%s", (new_qty, id))
    cursor.execute("UPDATE products SET quantity=%s WHERE id=%s", (stock_available - new_qty, product_id))
    db.commit()
    return redirect("/cart")


# ---------------- Checkout ----------------
@app.route("/checkout")
def checkout():
    if 'user' not in session:
        return redirect("/user_login")

    user_id = session['user']

    cursor.execute("""
        SELECT o.product_id, o.quantity, p.price
        FROM orders o
        JOIN products p ON o.product_id = p.id
        WHERE o.user_id=%s
    """, (user_id,))
    items = cursor.fetchall()

    if not items:
        flash("Cart is empty!")
        return redirect("/cart")

    import uuid
    order_number = str(uuid.uuid4())[:8].upper()

    try:
        values = [
            (order_number, user_id, i['product_id'], i['quantity'], i['price'], 'Pending')
            for i in items
        ]

        cursor.executemany("""
            INSERT INTO order_history
            (order_number, user_id, product_id, quantity, price, status)
            VALUES (%s,%s,%s,%s,%s,%s)
        """, values)

        # Clear cart
        cursor.execute("DELETE FROM orders WHERE user_id=%s", (user_id,))
        db.commit()

    except Exception as e:
        db.rollback()
        flash("Something went wrong!")
        return redirect("/cart")

    return redirect(f"/payment/{order_number}")

#------------------payments------------------
@app.route("/payment/<order_number>")
def payment(order_number):
    return render_template("payment.html", order_number=order_number)

@app.route("/payment_success/<order_number>")
def payment_success(order_number):

    try:
        cursor.execute("""
            UPDATE order_history 
            SET status='Paid'
            WHERE order_number=%s
        """, (order_number,))
        db.commit()

        flash("Payment Successful!")

    except:
        db.rollback()
        flash("Payment update failed!")

    return redirect("/my_orders")
# ---------------- My Orders ----------------
from collections import defaultdict

@app.route("/my_orders")
def my_orders():
    if 'user' not in session:
        return redirect("/user_login")

    user_id = session['user']

    cursor.execute("""
        SELECT 
            oh.order_number,
            oh.quantity,
            oh.price,
            oh.status,
            DATE(oh.created_at) as order_date,
            p.name as product_name,
            p.image as product_image
        FROM order_history oh
        JOIN products p ON oh.product_id = p.id
        WHERE oh.user_id=%s
        ORDER BY oh.id DESC
    """, (user_id,))

    orders = cursor.fetchall()

    # 🔥 GROUP BY order_number
    grouped_orders = defaultdict(list)

    for order in orders:
        grouped_orders[order['order_number']].append(order)

    return render_template("my_orders.html", grouped_orders=grouped_orders)
#-------------------------------cancel order---------------------------

@app.route("/cancel_order/<order_number>", methods=["POST"])
def cancel_order(order_number):

    if 'user' not in session:
        return redirect("/user_login")

    try:
        cursor.execute("""
            UPDATE order_history
            SET status='Cancelled'
            WHERE order_number=%s
            AND status IN ('Pending','Paid')
        """, (order_number,))

        db.commit()
        flash("Order cancelled successfully!")

    except:
        db.rollback()
        flash("Error cancelling order!")

    return redirect("/my_orders")


# ---------------- Logout ----------------
@app.route("/logout")
def logout():
    session.clear()
    return redirect("/user_login")


# ---------------- Utility ----------------
def get_cart_count(user_id):
    cursor.execute("SELECT SUM(quantity) AS cart_count FROM orders WHERE user_id=%s", (user_id,))
    return cursor.fetchone()['cart_count'] or 0


