<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Panel — Ravi Mart</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{min-height:100%;font-family:'Inter',sans-serif;background:#0a0a0a;color:#f0ede6}

.layout{display:flex;min-height:100vh}

/* SIDEBAR */
.sidebar{width:220px;background:rgba(255,255,255,0.02);border-right:1px solid rgba(255,255,255,0.06);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh}
.sb-logo{padding:20px;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:10px}
.sb-logo-icon{width:32px;height:32px;border-radius:9px;background:linear-gradient(135deg,#f59e0b,#d97706);display:flex;align-items:center;justify-content:center}
.sb-logo-icon svg{width:15px;height:15px;stroke:#fff;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.sb-logo-text{font-size:14px;font-weight:600;color:#f0ede6}
.sb-logo-sub{font-size:10px;color:rgba(240,237,230,0.3)}
.sb-nav{flex:1;padding:12px 10px;display:flex;flex-direction:column;gap:2px}
.sb-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;font-size:13px;font-weight:500;color:rgba(240,237,230,0.5);text-decoration:none;transition:background 0.12s,color 0.12s;cursor:pointer;border:none;background:transparent;width:100%}
.sb-item:hover{background:rgba(255,255,255,0.04);color:rgba(240,237,230,0.85)}
.sb-item.active{background:rgba(245,158,11,0.1);color:#f59e0b}
.sb-item svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}
.sb-sep{height:1px;background:rgba(255,255,255,0.05);margin:8px 10px}
.sb-section{font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:rgba(240,237,230,0.2);padding:6px 12px 4px}
.sb-badge{margin-left:auto;font-size:10px;font-weight:600;background:rgba(239,68,68,0.2);color:#f87171;padding:1px 7px;border-radius:99px}
.sb-bottom{padding:12px 10px;border-top:1px solid rgba(255,255,255,0.06)}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;min-width:0}
.topbar{background:rgba(10,10,10,0.8);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.06);padding:0 2rem;height:56px;display:flex;align-items:center;justify-content:space-between}
.topbar-title{font-size:14px;font-weight:600;color:#f0ede6}
.topbar-right{display:flex;align-items:center;gap:12px}
.topbar-time{font-size:11px;color:rgba(240,237,230,0.3)}
.topbar-admin{display:flex;align-items:center;gap:8px;font-size:12px;color:rgba(240,237,230,0.5)}
.topbar-avatar{width:28px;height:28px;border-radius:50%;background:rgba(239,68,68,0.15);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#f87171}

.content{flex:1;padding:2rem}

/* STATS */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:2rem}
.kpi{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:14px;padding:18px 20px}
.kpi-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:rgba(240,237,230,0.3);margin-bottom:10px;display:flex;align-items:center;justify-content:space-between}
.kpi-icon{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center}
.kpi-icon svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.kpi-num{font-size:26px;font-weight:700;letter-spacing:-0.03em;color:#f0ede6}
.kpi-trend{font-size:11px;margin-top:4px}
.kpi-up{color:#4ade80} .kpi-dn{color:#f87171}

/* GRID */
.dash-grid{display:grid;grid-template-columns:1fr 340px;gap:1.5rem}

/* ORDERS TABLE */
.panel{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;overflow:hidden}
.panel-head{padding:14px 18px;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:space-between}
.panel-title{font-size:13px;font-weight:600;color:#f0ede6}
.filter-tabs{display:flex;gap:4px}
.ftab{font-size:11px;padding:4px 10px;border-radius:8px;border:none;background:transparent;color:rgba(240,237,230,0.4);cursor:pointer;transition:all 0.12s}
.ftab:hover{background:rgba(255,255,255,0.05);color:rgba(240,237,230,0.7)}
.ftab.active{background:rgba(245,158,11,0.12);color:#f59e0b}

.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse}
.th{padding:10px 18px;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:rgba(240,237,230,0.3);text-align:left;background:rgba(255,255,255,0.02);border-bottom:1px solid rgba(255,255,255,0.05)}
.td{padding:13px 18px;font-size:12px;color:rgba(240,237,230,0.75);border-bottom:1px solid rgba(255,255,255,0.04)}
tr:hover td{background:rgba(255,255,255,0.02)}
tr:last-child td{border-bottom:none}
.td-bold{font-weight:600;color:#f0ede6}
.status-pill{font-size:10px;font-weight:500;padding:3px 10px;border-radius:99px;white-space:nowrap}
.s-delivered{background:rgba(34,197,94,0.12);color:#4ade80}
.s-pending{background:rgba(245,158,11,0.12);color:#fbbf24}
.s-transit{background:rgba(59,130,246,0.12);color:#60a5fa}
.s-cancelled{background:rgba(239,68,68,0.12);color:#f87171}
.s-confirmed{background:rgba(139,92,246,0.12);color:#a78bfa}
.action-btn{font-size:11px;padding:4px 10px;border-radius:7px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:rgba(240,237,230,0.5);cursor:pointer;transition:all 0.12s;text-decoration:none;display:inline-block}
.action-btn:hover{border-color:rgba(255,255,255,0.2);color:#f0ede6}
.action-btn.accept{border-color:rgba(34,197,94,0.3);color:#4ade80}
.action-btn.accept:hover{background:rgba(34,197,94,0.1)}
.action-btn.reject{border-color:rgba(239,68,68,0.3);color:#f87171}
.action-btn.reject:hover{background:rgba(239,68,68,0.1)}

/* RIGHT PANEL */
.mini-panel{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;overflow:hidden;margin-bottom:1.5rem}
.mp-head{padding:14px 18px;border-bottom:1px solid rgba(255,255,255,0.06)}
.mp-title{font-size:13px;font-weight:600;color:#f0ede6}

.rider-row{display:flex;align-items:center;gap:12px;padding:12px 18px;border-bottom:1px solid rgba(255,255,255,0.04)}
.rider-row:last-child{border-bottom:none}
.rider-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.rd-online{background:#22c55e;box-shadow:0 0 0 2px rgba(34,197,94,0.2)}
.rd-busy{background:#f59e0b}
.rd-offline{background:rgba(255,255,255,0.15)}
.rider-name{font-size:12px;font-weight:500;color:#f0ede6;flex:1}
.rider-status{font-size:11px;color:rgba(240,237,230,0.35)}
.rider-orders{font-size:11px;font-weight:500;color:rgba(240,237,230,0.5)}

.quick-actions{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:14px}
.qa-btn{display:flex;flex-direction:column;align-items:center;gap:6px;padding:14px 10px;border:1px solid rgba(255,255,255,0.07);border-radius:12px;text-decoration:none;transition:border-color 0.15s,background 0.15s}
.qa-btn:hover{border-color:rgba(255,255,255,0.14);background:rgba(255,255,255,0.02)}
.qa-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center}
.qa-icon svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.qa-label{font-size:11px;font-weight:500;color:rgba(240,237,230,0.6);text-align:center}

@media(max-width:900px){
  .sidebar{display:none}
  .kpi-grid{grid-template-columns:repeat(2,1fr)}
  .dash-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<div class="layout">
  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sb-logo">
      <div class="sb-logo-icon">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg>
      </div>
      <div>
        <div class="sb-logo-text">Ravi Mart</div>
        <div class="sb-logo-sub">Admin panel</div>
      </div>
    </div>
    <nav class="sb-nav">
      <div class="sb-section">Overview</div>
      <a href="/admin_dashboard" class="sb-item active">
        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a href="/admin_orders" class="sb-item">
        <svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        Orders
        <span class="sb-badge">{{ pending_count }}</span>
      </a>
      <div class="sb-sep"></div>
      <div class="sb-section">Manage</div>
      <a href="/admin_products" class="sb-item">
        <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
        Products
      </a>
      <a href="/admin_riders" class="sb-item">
        <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Riders
      </a>
      <a href="/admin_users" class="sb-item">
        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        Users
      </a>
      <a href="/admin_inventory" class="sb-item">
        <svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        Inventory
      </a>
    </nav>
    <div class="sb-bottom">
      <a href="/logout" class="sb-item">
        <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign out
      </a>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="main">
    <div class="topbar">
      <span class="topbar-title">Dashboard overview</span>
      <div class="topbar-right">
        <span class="topbar-time" id="topbar-time">—</span>
        <div class="topbar-admin">
          <div class="topbar-avatar">A</div>
          Admin
        </div>
      </div>
    </div>

    <div class="content">
      <!-- KPIs -->
      <div class="kpi-grid">
        <div class="kpi">
          <div class="kpi-label">
            Today's orders
            <div class="kpi-icon" style="background:rgba(245,158,11,0.1)">
              <svg viewBox="0 0 24 24" style="stroke:#f59e0b"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/></svg>
            </div>
          </div>
          <div class="kpi-num">{{ today_orders }}</div>
          <div class="kpi-trend kpi-up">↑ 12% vs yesterday</div>
        </div>
        <div class="kpi">
          <div class="kpi-label">
            Revenue today
            <div class="kpi-icon" style="background:rgba(34,197,94,0.1)">
              <svg viewBox="0 0 24 24" style="stroke:#4ade80"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            </div>
          </div>
          <div class="kpi-num">₹{{ today_revenue }}</div>
          <div class="kpi-trend kpi-up">↑ 8% vs yesterday</div>
        </div>
        <div class="kpi">
          <div class="kpi-label">
            Pending orders
            <div class="kpi-icon" style="background:rgba(239,68,68,0.1)">
              <svg viewBox="0 0 24 24" style="stroke:#f87171"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
          </div>
          <div class="kpi-num" style="color:#f87171">{{ pending_orders }}</div>
          <div class="kpi-trend" style="color:rgba(240,237,230,0.3)">Needs action</div>
        </div>
        <div class="kpi">
          <div class="kpi-label">
            Active riders
            <div class="kpi-icon" style="background:rgba(59,130,246,0.1)">
              <svg viewBox="0 0 24 24" style="stroke:#60a5fa"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/></svg>
            </div>
          </div>
          <div class="kpi-num" style="color:#60a5fa">{{ active_riders }}</div>
          <div class="kpi-trend kpi-up">{{ online_riders }} online now</div>
        </div>
      </div>

      <div class="dash-grid">
        <!-- ORDERS TABLE -->
        <div class="panel">
          <div class="panel-head">
            <span class="panel-title">Live orders</span>
            <div class="filter-tabs">
              <button class="ftab active" onclick="filterOrders('all',this)">All</button>
              <button class="ftab" onclick="filterOrders('pending',this)">Pending</button>
              <button class="ftab" onclick="filterOrders('confirmed',this)">Confirmed</button>
              <button class="ftab" onclick="filterOrders('transit',this)">In transit</button>
            </div>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th class="th">Order</th>
                  <th class="th">Customer</th>
                  <th class="th">Items</th>
                  <th class="th">Amount</th>
                  <th class="th">Status</th>
                  <th class="th">Actions</th>
                </tr>
              </thead>
              <tbody id="orders-tbody">
                {% for order in orders %}
                <tr data-status="{{ order.status }}">
                  <td class="td td-bold">#{{ order.order_number }}</td>
                  <td class="td">{{ order.customer_name }}</td>
                  <td class="td">{{ order.items_count }} items</td>
                  <td class="td td-bold">₹{{ order.total }}</td>
                  <td class="td"><span class="status-pill s-{{ order.status }}">{{ order.status|capitalize }}</span></td>
                  <td class="td" style="display:flex;gap:6px;flex-wrap:wrap">
                    {% if order.status == 'pending' %}
                    <a href="/admin/accept_order/{{ order.id }}" class="action-btn accept">Accept</a>
                    <a href="/admin/reject_order/{{ order.id }}" class="action-btn reject">Reject</a>
                    {% elif order.status == 'confirmed' %}
                    <a href="/admin/assign_rider/{{ order.id }}" class="action-btn">Assign rider</a>
                    {% else %}
                    <a href="/admin/order/{{ order.id }}" class="action-btn">View</a>
                    {% endif %}
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>

        <!-- RIGHT PANEL -->
        <div>
          <!-- RIDER STATUS -->
          <div class="mini-panel">
            <div class="mp-head">
              <div class="mp-title">Rider status</div>
            </div>
            {% for rider in riders %}
            <div class="rider-row">
              <div class="rider-dot rd-{{ rider.status }}"></div>
              <span class="rider-name">{{ rider.name }}</span>
              <span class="rider-orders">{{ rider.active_deliveries }} active</span>
              <span class="rider-status">{{ rider.status|capitalize }}</span>
            </div>
            {% endfor %}
          </div>

          <!-- QUICK ACTIONS -->
          <div class="mini-panel">
            <div class="mp-head">
              <div class="mp-title">Quick actions</div>
            </div>
            <div class="quick-actions">
              <a href="/admin/add_product" class="qa-btn">
                <div class="qa-icon" style="background:rgba(245,158,11,0.1)">
                  <svg viewBox="0 0 24 24" style="stroke:#f59e0b"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </div>
                <span class="qa-label">Add product</span>
              </a>
              <a href="/admin/manage_riders" class="qa-btn">
                <div class="qa-icon" style="background:rgba(59,130,246,0.1)">
                  <svg viewBox="0 0 24 24" style="stroke:#60a5fa"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                </div>
                <span class="qa-label">Manage riders</span>
              </a>
              <a href="/admin/inventory" class="qa-btn">
                <div class="qa-icon" style="background:rgba(34,197,94,0.1)">
                  <svg viewBox="0 0 24 24" style="stroke:#4ade80"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/></svg>
                </div>
                <span class="qa-label">Inventory</span>
              </a>
              <a href="/admin/reports" class="qa-btn">
                <div class="qa-icon" style="background:rgba(139,92,246,0.1)">
                  <svg viewBox="0 0 24 24" style="stroke:#a78bfa"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                </div>
                <span class="qa-label">Reports</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function filterOrders(status, btn) {
  document.querySelectorAll('.ftab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('#orders-tbody tr').forEach(row => {
    row.style.display = (status === 'all' || row.dataset.status === status) ? '' : 'none';
  });
}
function tick() {
  const now = new Date();
  document.getElementById('topbar-time').textContent = now.toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
}
tick(); setInterval(tick, 1000);
</script>
</body>
</html>