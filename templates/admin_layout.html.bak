<!DOCTYPE html>
<html>
<head>
<title>Admin Panel</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
display:flex;
background:#f5f7fb;
}

/* SIDEBAR */

.sidebar{
width:240px;
height:100vh;
background:#1f2a40;
color:white;
position:fixed;
padding:25px 15px;
}

.sidebar h2{
margin-bottom:30px;
text-align:center;
}

.sidebar a{
display:block;
padding:12px;
margin-bottom:10px;
color:white;
text-decoration:none;
border-radius:6px;
transition:0.3s;
}

.sidebar a:hover{
background:#32405c;
}

/* MAIN AREA */

.main{
margin-left:240px;
width:100%;
}

/* HEADER */

.header{
background:white;
padding:15px 25px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
display:flex;
justify-content:space-between;
align-items:center;
}

.logout-btn{
background:#e74c3c;
border:none;
color:white;
padding:8px 15px;
border-radius:5px;
cursor:pointer;
}

/* CONTENT */

.content{
padding:25px;
}

/* STATS */

.stats{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-bottom:20px;
}

.card{
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 3px 8px rgba(0,0,0,0.1);
text-align:center;
}

.card h4{
color:#777;
}

.card h3{
margin-top:5px;
font-size:22px;
}

/* TABLE */

table{
width:100%;
border-collapse:collapse;
background:white;
border-radius:10px;
overflow:hidden;
box-shadow:0 3px 8px rgba(0,0,0,0.1);
}

th,td{
padding:12px;
text-align:center;
}

th{
background:#1f2a40;
color:white;
}

tr:nth-child(even){
background:#f8f8f8;
}

img{
width:50px;
height:50px;
object-fit:cover;
border-radius:5px;
}

/* STATUS */

.status{
padding:4px 10px;
border-radius:5px;
color:white;
font-size:12px;
}

.Pending{background:#f39c12;}
.Completed{background:#27ae60;}
.Cancelled{background:#e74c3c;}
.Assigned{background:#3498db;}
.Delivered{background:#2ecc71;}
/* Payment Status */

.Paid{
background:#27ae60;
color:white;
}

.PendingPayment{
background:#e67e22;
color:white;
}

.Failed{
background:#e74c3c;
color:white;
}
/* BUTTONS */

button{
border:none;
padding:6px 10px;
border-radius:5px;
cursor:pointer;
}

.complete{
background:#27ae60;
color:white;
}

.cancel{
background:#e74c3c;
color:white;
}

.assign{
background:#2980b9;
color:white;
}

</style>

</head>

<body>

<!-- SIDEBAR -->

<div class="sidebar">

<h2>🛍 Ravi Mart</h2>

<a href="{{ url_for('admin_dashboard') }}">Dashboard</a>
<a href="{{ url_for('admin_orders') }}">Orders</a>
<a href="{{ url_for('admin_riders') }}">Riders</a>
<a href="/admin_logout">Logout</a>

</div>


<div class="main">

<div class="header">
<h3>Admin Panel</h3>

<button class="logout-btn"
onclick="window.location.href='/admin_logout'">
Logout
</button>
</div>


<div class="content">

{% block content %}

{% endblock %}

</div>

</div>

</body>
</html>