{% extends "admin_layout.html" %}

{% block content %}

<style>

body{
background:#0a0a0a;
color:#e5e5e5;
}

/* Stats */

.stats{
display:flex;
gap:20px;
margin-bottom:25px;
flex-wrap:wrap;
}

.card{
background:#111;
padding:20px;
border-radius:10px;
border:1px solid #222;
flex:1;
min-width:180px;
text-align:center;
}

.card h4{
font-size:14px;
color:#888;
margin-bottom:8px;
}

.card h3{
font-size:24px;
color:#fff;
}

/* Table */

table{
width:100%;
border-collapse:collapse;
background:#111;
border-radius:10px;
overflow:hidden;
border:1px solid #222;
}

th,td{
padding:12px;
text-align:center;
border-bottom:1px solid #222;
}

th{
background:#181818;
font-size:13px;
text-transform:uppercase;
color:#aaa;
}

td{
color:#ddd;
}

td img{
width:50px;
height:50px;
object-fit:cover;
border-radius:6px;
}

/* Status */

.status{
padding:4px 10px;
border-radius:6px;
font-size:12px;
font-weight:500;
}

.status.Pending{
background:#f59e0b;
color:#000;
}

.status.Completed{
background:#22c55e;
color:#000;
}

.status.Cancelled{
background:#ef4444;
color:#fff;
}

.status.Paid{
background:#22c55e;
color:#000;
}

.status.PendingPayment{
background:#f59e0b;
color:#000;
}

/* Form */

select{
padding:6px;
border-radius:6px;
background:#181818;
border:1px solid #333;
color:#fff;
}

/* Buttons */

button{
border:none;
padding:6px 10px;
border-radius:6px;
cursor:pointer;
}

.assign{
background:#3b82f6;
color:#fff;
}

.complete{
background:#22c55e;
color:#000;
}

.cancel{
background:#ef4444;
color:#fff;
}

button:hover{
opacity:.85;
}

</style>

<h2 style="margin-bottom:15px;">📦 Orders</h2>

<div class="stats">

<div class="card">
<h4>Total Orders</h4>
<h3>{{ total_orders }}</h3>
</div>

<div class="card">
<h4>Pending</h4>
<h3>{{ pending_orders }}</h3>
</div>

<div class="card">
<h4>Completed</h4>
<h3>{{ completed_orders }}</h3>
</div>

<div class="card">
<h4>Revenue</h4>
<h3>₹{{ revenue }}</h3>
</div>

</div>

<table>

<thead>
<tr>
<th>Order</th>
<th>User</th>
<th>Product</th>
<th>Image</th>
<th>Qty</th>
<th>Total</th>
<th>Status</th>
<th>Payment</th>
<th>Date</th>
<th>Assign Rider</th>
<th>Action</th>
</tr>
</thead>

<tbody>

{% for order in orders %}

<tr>

<td>{{ order.order_number }}</td>
<td>{{ order.username }}</td>
<td>{{ order.name }}</td>

<td>
<img src="{{ url_for('static', filename=order.image) }}">
</td>

<td>{{ order.quantity }}</td>

<td>₹{{ order.price * order.quantity }}</td>

<td>
<span class="status {{ order.status }}">{{ order.status }}</span>
</td>

<td>
<span class="status {{ order.payment_status if order.payment_status else 'PendingPayment' }}">
{{ order.payment_status if order.payment_status else 'Pending' }}
</span>
</td>

<td>{{ order.created_at }}</td>

<td>

{% if order.rider_id %}
Assigned
{% else %}

<form method="POST" action="/assign_rider">

<input type="hidden" name="order_id" value="{{ order.id }}">

<select name="rider_id">

<option value="">Select Rider</option>

{% for rider in riders %}
<option value="{{ rider.id }}">{{ rider.name }}</option>
{% endfor %}

</select>

<button class="assign">Assign</button>

</form>

{% endif %}

</td>

<td>

<button class="complete"
onclick="location.href='{{ url_for('update_order_status',order_id=order.id,status='Completed') }}'">
Complete
</button>

<button class="cancel"
onclick="location.href='{{ url_for('update_order_status',order_id=order.id,status='Cancelled') }}'">
Cancel
</button>

</td>

</tr>

{% endfor %}

</tbody>

</table>

{% endblock %}