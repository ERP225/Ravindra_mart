<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Your Cart — Ravi Mart</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{margin:0;padding:0;box-sizing:border-box}

body{
font-family:'Inter',sans-serif;
background:#0a0a0a;
color:#f0ede6;
padding:30px;
}

.page{
max-width:900px;
margin:auto;
}

.page-title{
font-size:24px;
font-weight:700;
margin-bottom:20px;
}

.card{
background:rgba(255,255,255,0.03);
border:1px solid rgba(255,255,255,0.07);
border-radius:16px;
padding:20px;
}

table{
width:100%;
border-collapse:collapse;
margin-top:10px;
}

th,td{
padding:12px;
text-align:center;
border-bottom:1px solid rgba(255,255,255,0.08);
}

th{
font-size:13px;
color:rgba(240,237,230,0.5);
text-transform:uppercase;
}

.product-img{
width:50px;
height:50px;
object-fit:cover;
border-radius:8px;
}

.qty-input{
width:60px;
padding:6px;
border-radius:6px;
border:1px solid rgba(255,255,255,0.2);
background:#111;
color:#fff;
}

.btn{
padding:8px 14px;
border:none;
border-radius:8px;
cursor:pointer;
font-size:13px;
}

.btn-update{
background:#22c55e;
color:#000;
}

.btn-remove{
background:#ef4444;
color:#fff;
}

.btn-checkout{
background:#f59e0b;
color:#000;
padding:12px 20px;
font-weight:600;
}

.btn-back{
background:#333;
color:#fff;
}

.total-row td{
font-weight:700;
font-size:16px;
}

.actions{
display:flex;
justify-content:space-between;
margin-top:20px;
}

.empty-msg{
text-align:center;
padding:40px;
color:rgba(240,237,230,0.4);
font-size:18px;
}

</style>
</head>

<body>

<div class="page">

<div class="page-title">🛒 Your Cart</div>

<div class="card">

{% if items %}

<table>

<tr>
<th>Product</th>
<th>Image</th>
<th>Price</th>
<th>Quantity</th>
<th>Total</th>
<th>Action</th>
</tr>

{% for item in items %}

<tr>

<td>{{ item.name }}</td>

<td>
<img src="{{ url_for('static', filename=item.image) }}" class="product-img">
</td>

<td>₹{{ item.price }}</td>

<td>

<form action="/update_cart/{{ item.product_id }}" method="POST">

<input type="number" name="qty" value="{{ item.quantity }}" min="1" class="qty-input">

<button type="submit" class="btn btn-update">Update</button>

</form>

</td>

<td>₹{{ item.price * item.quantity }}</td>

<td>
<a href="/remove_item/{{ item.id }}">
<button class="btn btn-remove">Remove</button>
</a>
</td>

</tr>

{% endfor %}

<tr class="total-row">

<td colspan="4">Grand Total</td>
<td colspan="2">₹{{ total }}</td>

</tr>

</table>

<div class="actions">

<a href="/user_dashboard">
<button class="btn btn-back">← Continue Shopping</button>
</a>

<a href="/checkout">
<button class="btn btn-checkout">Proceed to Checkout</button>
</a>

</div>

{% else %}

<div class="empty-msg">
Your cart is empty.
</div>

<a href="/user_dashboard">
<button class="btn btn-back">← Back to Home</button>
</a>

{% endif %}

</div>

</div>

</body>
</html>