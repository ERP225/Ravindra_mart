  }
  .nav-icon svg { width: 15px; height: 15px; stroke: #ffc83c; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
  .nav-name { font-size: 18px; color: #f5f0e8; letter-spacing: 0.02em; }
  .nav-year {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; color: rgba(255,255,255,0.3);
    letter-spacing: 0.08em; text-transform: uppercase;
  }

  /* LAYOUT */
  .page {
    min-height: calc(100vh - 60px);
    display: grid;
    grid-template-columns: 55% 45%;
    grid-template-rows: 1fr auto;
  }

  /* HERO */
  .hero {
    padding: 5rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .hero-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: #ffc83c; margin-bottom: 2rem;
    display: flex; align-items: center; gap: 8px;
  }
  .hero-tag-line { width: 24px; height: 1px; background: #ffc83c; }
  .hero-h1 { font-size: 56px; line-height: 1.05; color: #f5f0e8; margin-bottom: 1.5rem; font-style: italic; }
  .hero-h1 span { font-style: normal; color: #ffc83c; }
  .hero-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px; line-height: 1.7;
    color: rgba(255,255,255,0.45);
    max-width: 400px; margin-bottom: 3.5rem; font-weight: 300;
  }
  .metrics {
    display: flex;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    overflow: hidden;
    width: fit-content;
  }
  .metric { padding: 18px 28px; text-align: center; }
  .metric + .metric { border-left: 1px solid rgba(255,255,255,0.1); }
  .metric-num { font-size: 22px; color: #f5f0e8; font-style: italic; }
  .metric-lbl {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; color: rgba(255,255,255,0.35);
    margin-top: 3px; text-transform: uppercase; letter-spacing: 0.07em;
  }

  /* SIDEBAR */
  .sidebar {
    padding: 3rem 2.5rem;
    display: flex; flex-direction: column; justify-content: center;
  }
  .sidebar-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(255,255,255,0.25); margin-bottom: 1.5rem;
  }
  .link-list { display: flex; flex-direction: column; gap: 6px; }
  .link-item {
    display: flex; align-items: center; gap: 14px;
    padding: 16px 18px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.07);
    text-decoration: none;
    background: rgba(255,255,255,0.02);
    transition: background 0.15s, border-color 0.15s;
  }
  .link-item:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.15); }
  .link-dot {
    width: 36px; height: 36px; border-radius: 8px;
    flex-shrink: 0; display: flex; align-items: center; justify-content: center;
  }
  .link-dot svg { width: 16px; height: 16px; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
  .d-blue  { background: rgba(100,160,255,0.1); } .d-blue  svg { stroke: #64a0ff; }
  .d-green { background: rgba(100,210,130,0.1); } .d-green svg { stroke: #64d282; }
  .d-amber { background: rgba(255,200,60,0.1);  } .d-amber svg { stroke: #ffc83c; }
  .d-pink  { background: rgba(240,130,170,0.1); } .d-pink  svg { stroke: #f082aa; }
  .d-red   { background: rgba(240,90,90,0.1);   } .d-red   svg { stroke: #f05a5a; }
  .link-body { flex: 1; }
  .link-title { font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.85); }
  .link-desc  { font-family: 'DM Sans', sans-serif; font-size: 11px; color: rgba(255,255,255,0.3); margin-top: 2px; }
  .link-arr   { font-size: 16px; color: rgba(255,255,255,0.2); }

  /* SEPARATOR */
  .sep { display: flex; align-items: center; gap: 10px; margin: 8px 0; }
  .sep-line { flex: 1; height: 1px; background: rgba(255,255,255,0.06); }
  .sep-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px; color: rgba(255,255,255,0.2);
    letter-spacing: 0.08em; text-transform: uppercase;
  }

  /* FOOTER */
  footer {
    grid-column: 1 / -1;
    background: #0c0c0b;
    border-top: 1px solid rgba(255,255,255,0.06);
    text-align: center; padding: 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; color: rgba(255,255,255,0.2); letter-spacing: 0.04em;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .page { grid-template-columns: 1fr; }
    .hero { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); padding: 3rem 1.5rem; }
    .hero-h1 { font-size: 38px; }
    .sidebar { padding: 2rem 1.5rem; }
    .metrics { flex-wrap: wrap; }
    footer { grid-column: 1; }
