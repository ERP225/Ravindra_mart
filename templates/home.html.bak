  }
  .nav-dot { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 0 2px rgba(34,197,94,0.2); }

  /* ── TICKER ── */
  .ticker {
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding: 12px 0; overflow: hidden; margin-bottom: 0;
  }
  .ticker-track { display: flex; gap: 48px; width: max-content; animation: tick 18s linear infinite; }
  .ticker-item {
    display: flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 500; color: rgba(240,237,230,0.3);
    letter-spacing: 0.05em; white-space: nowrap;
  }
  .ticker-dot { width: 3px; height: 3px; border-radius: 50%; background: rgba(245,158,11,0.6); }
  @keyframes tick { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  /* ── HERO ── */
  .hero {
    padding: 5rem 2rem 3rem;
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 420px; gap: 4rem; align-items: center;
  }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    color: #f59e0b; margin-bottom: 1.5rem;
  }
  .hero-eyebrow-dot { width: 4px; height: 4px; border-radius: 50%; background: #f59e0b; }
  .hero-h1 {
    font-size: 52px; font-weight: 700; line-height: 1.08;
    letter-spacing: -0.03em; color: #f0ede6; margin-bottom: 1.25rem;
  }
  .hero-h1 em { font-style: normal; color: #f59e0b; }
  .hero-p {
    font-size: 15px; font-weight: 300; line-height: 1.75;
    color: rgba(240,237,230,0.5); max-width: 400px; margin-bottom: 2.5rem;
  }
  .stats-row { display: flex; border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; overflow: hidden; width: fit-content; }
  .stat { padding: 16px 24px; text-align: center; }
  .stat + .stat { border-left: 1px solid rgba(255,255,255,0.08); }
  .stat-n { font-size: 22px; font-weight: 700; color: #f0ede6; letter-spacing: -0.02em; }
  .stat-l { font-size: 10px; font-weight: 500; color: rgba(240,237,230,0.35); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.07em; }

  /* ── PANEL ── */
  .panel {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px; padding: 2rem;
    display: flex; flex-direction: column; gap: 8px;
  }
  .panel-head {
    font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(240,237,230,0.3); margin-bottom: 4px;
  }

  /* ── ENTRY BUTTONS ── */
  .entry-btn {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 16px; border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.02);
    text-decoration: none;
    transition: background 0.12s, border-color 0.12s, transform 0.1s;
    position: relative; overflow: hidden;
  }
  .entry-btn::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent);
    transform: translateX(-100%); transition: transform 0.4s;
  }
  .entry-btn:hover::before { transform: translateX(100%); }
  .entry-btn:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.14); transform: translateY(-1px); }
  .entry-btn:active { transform: translateY(0); }

  .btn-icon { width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
  .btn-icon svg { width: 16px; height: 16px; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
  .ic-blue  { background: rgba(59,130,246,0.12); }  .ic-blue  svg { stroke: #60a5fa; }
  .ic-green { background: rgba(34,197,94,0.12); }   .ic-green svg { stroke: #4ade80; }
  .ic-amber { background: rgba(245,158,11,0.12); }  .ic-amber svg { stroke: #fbbf24; }
  .ic-pink  { background: rgba(236,72,153,0.12); }  .ic-pink  svg { stroke: #f472b6; }
  .ic-red   { background: rgba(239,68,68,0.12); }   .ic-red   svg { stroke: #f87171; }

  .btn-body { flex: 1; min-width: 0; }
  .btn-title { font-size: 13px; font-weight: 500; color: rgba(240,237,230,0.9); line-height: 1.3; }
  .btn-sub { font-size: 11px; color: rgba(240,237,230,0.35); margin-top: 2px; }
  .btn-arrow { font-size: 16px; color: rgba(240,237,230,0.2); transition: transform 0.12s, color 0.12s; }
  .entry-btn:hover .btn-arrow { transform: translateX(2px); color: rgba(240,237,230,0.5); }

  /* ── SEPARATOR ── */
  .sep { display: flex; align-items: center; gap: 10px; margin: 2px 0; }
  .sep-line { flex: 1; height: 1px; background: rgba(255,255,255,0.06); }
