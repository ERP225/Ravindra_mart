<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Orders — Ravi Mart</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{min-height:100%;font-family:'Inter',sans-serif;background:#0a0a0a;color:#f0ede6}
.nav{background:rgba(10,10,10,0.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.06);padding:0 2rem;height:60px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.brand{display:flex;align-items:center;gap:12px}
.brand-logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#f59e0b,#d97706);display:flex;align-items:center;justify-content:center}
.brand-logo svg{width:18px;height:18px;stroke:#fff;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.brand-name{font-size:16px;font-weight:600;color:#f0ede6}
.nav-back{display:flex;align-items:center;gap:6px;font-size:13px;color:rgba(240,237,230,0.5);text-decoration:none;transition:color 0.15s}
.nav-back:hover{color:#f0ede6}
.nav-back svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.page{max-width:760px;margin:0 auto;padding:2.5rem 1.5rem}
.page-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem}
.page-title{font-size:22px;font-weight:700;letter-spacing:-0.02em}
.filter-tabs{display:flex;gap:6px}
.ftab{font-size:11px;font-weight:500;padding:6px 14px;border-radius:99px;border:1px solid rgba(255,255,255,0.09);background:transparent;color:rgba(240,237,230,0.45);cursor:pointer;transition:all 0.12s}
.ftab:hover{border-color:rgba(255,255,255,0.2);color:rgba(240,237,230,0.8)}
.ftab.active{background:rgba(245,158,11,0.12);border-color:rgba(245,158,11,0.3);color:#f59e0b}

/* ORDER CARD */
.order-card{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;overflow:hidden;margin-bottom:12px;transition:border-color 0.15s}
.order-card:hover{border-color:rgba(255,255,255,0.12)}

/* active order special border */
.order-card.live{border-color:rgba(59,130,246,0.3);background:rgba(59,130,246,0.03)}

.oc-head{padding:14px 18px;display:flex;align-items:center;gap:14px;border-bottom:1px solid rgba(255,255,255,0.05)}
.oc-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.oc-icon svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.oc-info{flex:1}
.oc-id{font-size:13px;font-weight:600;color:#f0ede6}
.oc-date{font-size:11px;color:rgba(240,237,230,0.35);margin-top:2px}
.oc-right{display:flex;align-items:center;gap:12px}
.oc-total{font-size:15px;font-weight:700;color:#f0ede6}
.status-pill{font-size:10px;font-weight:500;padding:4px 12px;border-radius:99px}
.s-delivered{background:rgba(34,197,94,0.12);color:#4ade80}
.s-pending{background:rgba(245,158,11,0.12);color:#fbbf24}
.s-transit{background:rgba(59,130,246,0.12);color:#60a5fa}
.s-confirmed{background:rgba(139,92,246,0.12);color:#a78bfa}
.s-cancelled{background:rgba(239,68,68,0.12);color:#f87171}

/* TRACKER */
.tracker{padding:16px 18px;border-bottom:1px solid rgba(255,255,255,0.05)}
.track-steps{display:flex;align-items:center;gap:0}
.track-step{display:flex;flex-direction:column;align-items:center;gap:5px}
.track-dot{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.track-dot.done{background:#16a34a}
.track-dot.active{background:#f59e0b}
.track-dot.idle{background:rgba(255,255,255,0.07)}
.track-dot svg{width:11px;height:11px;stroke:#fff;fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
.track-dot.idle svg{stroke:rgba(240,237,230,0.25)}
.track-label{font-size:10px;font-weight:500;color:rgba(240,237,230,0.4);text-align:center;white-space:nowrap}
.track-label.done{color:#4ade80}
.track-label.active{color:#f59e0b}
.track-line{flex:1;height:1px;background:rgba(255,255,255,0.07);margin-bottom:18px}
.track-line.done{background:#16a34a}

/* ITEMS */
.oc-items{padding:12px 18px;display:flex;flex-wrap:wrap;gap:8px}
.oc-item-chip{font-size:11px;padding:4px 10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:7px;color:rgba(240,237,230,0.6)}

/* ACTIONS */
.oc-actions{padding:12px 18px;border-top:1px solid rgba(255,255,255,0.05);display:flex;gap:8px}
.oc-btn{font-size:12px;font-weight:500;padding:8px 16px;border-radius:9px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:rgba(240,237,230,0.6);cursor:pointer;text-decoration:none;transition:all 0.12s;display:inline-flex;align-items:center;gap:6px}
.oc-btn:hover{border-color:rgba(255,255,255,0.2);color:#f0ede6}
.oc-btn svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.oc-btn.primary{background:#f59e0b;border-color:#f59e0b;color:#0a0a0a}
.oc-btn.primary:hover{background:#d97706;border-color:#d97706}

/* EMPTY */
.empty{text-align:center;padding:4rem 2rem}
.empty-icon{width:56px;height:56px;border-radius:16px;background:rgba(255,255,255,0.04);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem}
.empty-icon svg{width:24px;height:24px;stroke:rgba(240,237,230,0.2);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.empty-title{font-size:15px;font-weight:600;color:rgba(240,237,230,0.4);margin-bottom:6px}
.empty-sub{font-size:13px;color:rgba(240,237,230,0.2)}
</style>
</head>
<body>

<nav class="nav">
  <div class="brand">
    <div class="brand-logo">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
    </div>
    <span class="brand-name">Ravi Mart</span>
  </div>
  <a href="/user_dashboard" class="nav-back">
    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    Dashboard
  </a>
</nav>

<div class="page">
  <div class="page-head">
    <div class="page-title">My orders</div>
    <div class="filter-tabs">
      <button class="ftab active" onclick="filterTab('all',this)">All</button>
      <button class="ftab" onclick="filterTab('pending',this)">Active</button>
      <button class="ftab" onclick="filterTab('delivered',this)">Delivered</button>
      <button class="ftab" onclick="filterTab('cancelled',this)">Cancelled</button>
    </div>
  </div>

  <div id="orders-list">
    {% for order in orders %}

    {% set is_live = order.status in ['pending','confirmed','transit'] %}
    <div class="order-card {% if is_live %}live{% endif %}" data-status="{{ order.status }}">

      <!-- HEAD -->
      <div class="oc-head">
        <div class="oc-icon" style="background:{% if is_live %}rgba(59,130,246,0.1){% else %}rgba(245,158,11,0.1){% endif %}">
          <svg viewBox="0 0 24 24" style="stroke:{% if is_live %}#60a5fa{% else %}#f59e0b{% endif %}">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
          </svg>
        </div>
        <div class="oc-info">
          <div class="oc-id">#{{ order.order_number }}</div>
          <div class="oc-date">{{ order.created_at }} · {{ order.items_count }} items · {{ order.payment_method|upper }}</div>
        </div>
        <div class="oc-right">
          <span class="oc-total">₹{{ order.total }}</span>
          <span class="status-pill s-{{ order.status }}">{{ order.status|capitalize }}</span>
        </div>
      </div>

      <!-- TRACKER (only for active orders) -->
      {% if is_live %}
      <div class="tracker">
        <div class="track-steps">
          <div class="track-step">
            <div class="track-dot done"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>
            <div class="track-label done">Placed</div>
          </div>
          <div class="track-line {% if order.status in ['confirmed','transit'] %}done{% endif %}"></div>
          <div class="track-step">
            <div class="track-dot {% if order.status in ['confirmed','transit'] %}done{% elif order.status == 'pending' %}active{% else %}idle{% endif %}">
              <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div class="track-label {% if order.status in ['confirmed','transit'] %}done{% elif order.status == 'pending' %}active{% endif %}">Confirmed</div>
          </div>
          <div class="track-line {% if order.status == 'transit' %}done{% endif %}"></div>
          <div class="track-step">
            <div class="track-dot {% if order.status == 'transit' %}active{% else %}idle{% endif %}">
              <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/></svg>
            </div>
            <div class="track-label {% if order.status == 'transit' %}active{% endif %}">On the way</div>
          </div>
          <div class="track-line"></div>
          <div class="track-step">
            <div class="track-dot idle">
              <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div class="track-label">Delivered</div>
          </div>
        </div>
      </div>
      {% endif %}

      <!-- ITEMS -->
      <div class="oc-items">
        {% for item in order.items %}
        <span class="oc-item-chip">{{ item.name }} × {{ item.quantity }}</span>
        {% endfor %}
      </div>

      <!-- ACTIONS -->
      <div class="oc-actions">
        <a href="/order_summary/{{ order.id }}" class="oc-btn">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          View receipt
        </a>
        {% if is_live %}
        <a href="/track_order/{{ order.id }}" class="oc-btn primary">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Track order
        </a>
        {% endif %}
        {% if order.status == 'delivered' %}
        <a href="/reorder/{{ order.id }}" class="oc-btn">
          <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>
          Reorder
        </a>
        {% endif %}
        {% if order.status == 'pending' %}
        <a href="/cancel_order/{{ order.id }}" class="oc-btn" style="border-color:rgba(239,68,68,0.25);color:#f87171" onclick="return confirm('Cancel this order?')">
          Cancel order
        </a>
        {% endif %}
      </div>

    </div>
    {% else %}
    <div class="empty">
      <div class="empty-icon">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      </div>
      <div class="empty-title">No orders yet</div>
      <div class="empty-sub">Start shopping to see your orders here.</div>
    </div>
    {% endfor %}
  </div>
</div>

<script>
function filterTab(status, btn) {
  document.querySelectorAll('.ftab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.order-card').forEach(card => {
    if (status === 'all') { card.style.display = ''; return; }
    if (status === 'pending') {
      card.style.display = ['pending','confirmed','transit'].includes(card.dataset.status) ? '' : 'none';
    } else {
      card.style.display = card.dataset.status === status ? '' : 'none';
    }
  });
}
</script>
</body>
</html>