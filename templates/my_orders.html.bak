<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Orders - Ravi Mart</title>

<style>
body {
    font-family: 'Segoe UI', sans-serif;
    background:#f5f7fb;
    margin:0;
    padding:0;
}

.container {
    max-width:1000px;
    margin:20px auto;
    padding:20px;
    background:#fff;
    border-radius:12px;
    box-shadow:0 4px 15px rgba(0,0,0,0.1);
}

h2 {
    text-align:center;
    margin-bottom:20px;
}

table {
    width:100%;
    border-collapse:collapse;
}

th, td {
    padding:12px;
    text-align:center;
    border-bottom:1px solid #ccc;
}

th {
    background:#2c3e50;
    color:white;
}

tr:nth-child(even) {
    background:#f9f9f9;
}

img.product-img {
    width:60px;
    height:60px;
    object-fit:cover;
    border-radius:8px;
}

/* STATUS BADGES */

.status {
    padding:5px 10px;
    border-radius:6px;
    color:white;
    font-weight:500;
}

.status.pending{background:#f39c12;}
.status.completed{background:#27ae60;}
.status.cancelled{background:#e74c3c;}

.status.packed{background:#9b59b6;}
.status.shipped{background:#2980b9;}
.status.out_for_delivery{background:#f1c40f;}
.status.delivered{background:#27ae60;}

.status.paid{background:#27ae60;}
.status.Completed{background:#f39c12;}
.status.refunded{background:#3498db;}

/* Payment */

.Paid{background:#27ae60;}
.Unpaid{background:#f39c12;}
.Refunded{background:#3498db;}

/* REFUND AMOUNT STYLE */

.refund {
    color:#3498db;
    font-weight:bold;
}

/* BUTTONS */

.track-btn{
    background:#3498db;
    color:white;
    border:none;
    padding:6px 12px;
    border-radius:6px;
    cursor:pointer;
}

.back-btn {
    background:#555;
    color:white;
    border:none;
    padding:10px 20px;
    border-radius:8px;
    cursor:pointer;
    margin-top:20px;
}

</style>

</head>

<body>

<div class="container">

<h2>📝 My Orders</h2>

{% if orders %}

<table>

<tr>
    <th>Order No</th>
    <th>Product</th>
    <th>Image</th>
    <th>Qty</th>
    <th>Total Price</th>
    <th>Order Status</th>
    <th>Payment Status</th>
    <th>Refund</th>
    <th>Ordered On</th>
    <th>Track</th>
</tr>

{% for order in orders %}

<tr>

<td>{{ order.order_number }}</td>

<td>{{ order.name }}</td>

<td>
<img src="{{ url_for('static', filename=order.image) }}" class="product-img">
</td>

<td>{{ order.quantity }}</td>

<td>₹{{ order.price * order.quantity }}</td>

<td>
<span class="status {{ order.status|lower }}">
{{ order.status }}
</span>
</td>

<td>
<span class="status {{ order.payment_status|lower }}">
{{ order.payment_status }}
</span>
</td>

<td>
{% if order.payment_status == "Refunded" %}
<span class="refund">
₹{{ order.price * order.quantity }}
</span>
{% else %}
-
{% endif %}
</td>

<td>{{ order.created_at }}</td>

<td>
<a href="/track_order/{{ order.order_number }}">
<button class="track-btn">Track</button>
</a>
</td>

</tr>

{% endfor %}

</table>

{% else %}

<p style="text-align:center;">No orders found.</p>

{% endif %}

<a href="{{ url_for('user_dashboard') }}">
<button class="back-btn">Back to Home</button>
</a>

</div>

</body>
</html>