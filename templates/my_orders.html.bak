<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Orders - Ravi Mart</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
<style>
/* --- Page Layout --- */
body {
    font-family: 'Segoe UI', sans-serif;
    background:#f5f7fb;
    margin:0;
    padding:0;
}
.container {
    max-width:1000px;
    margin:20px auto;
    padding:20px;
    background:#fff;
    border-radius:12px;
    box-shadow:0 4px 15px rgba(0,0,0,0.1);
}
h2 {
    text-align:center;
    margin-bottom:20px;
}
table {
    width:100%;
    border-collapse:collapse;
}
th, td {
    padding:12px;
    text-align:center;
    border-bottom:1px solid #ccc;
}
th {
    background:#2c3e50;
    color:white;
}
tr:nth-child(even) {
    background:#f9f9f9;
}
img.product-img {
    width:60px;
    height:60px;
    object-fit:cover;
    border-radius:8px;
}

/* --- Status Badges --- */
.status {
    padding:5px 10px;
    border-radius:6px;
    font-weight:500;
    display:inline-block;
    min-width:80px;
}

/* Order Status */
.status.pending { background:#f39c12; color:black; }          /* yellow */
.status.out_for_delivery { background:#f1c40f; color:black; } /* orange */
.status.completed { background:#27ae60; color:white; }        /* green */
.status.delivered { background:#27ae60; color:white; }        /* green */
.status.cancelled { background:#e74c3c; color:white; }        /* red */
.status.packed { background:#9b59b6; color:white; }           /* purple */
.status.shipped { background:#2980b9; color:white; }          /* blue */

/* Payment Status */
.status.paid { background:#27ae60; color:white; }             /* green */
.status.unpaid { background:#f39c12; color:black; }           /* yellow/orange */
.status.refunded { background:#3498db; color:white; }         /* blue */

/* Refund text */
.refund {
    color:#3498db;
    font-weight:bold;
}

/* --- Buttons --- */
.track-btn {
    background:#3498db;
    color:white;
    border:none;
    padding:6px 12px;
    border-radius:6px;
    cursor:pointer;
}
.back-btn {
    background:#555;
    color:white;
    border:none;
    padding:10px 20px;
    border-radius:8px;
    cursor:pointer;
    margin-top:20px;
}

/* --- Map --- */
#map{
    height:400px;
    width:100%;
    margin-bottom:20px;
    border-radius:12px;
}
</style>
</head>
<body>
<div class="container">
<h2>📝 My Orders</h2>
<div id="map"></div>

<table>
<thead>
<tr>
<th>Order No</th>
<th>Product</th>
<th>Image</th>
<th>Qty</th>
<th>Total Price</th>
<th>Order Status</th>
<th>Payment Status</th>
<th>Refund</th>
<th>Ordered On</th>
<th>Track</th>
</tr>
</thead>
<tbody id="orders-tbody"></tbody>
</table>

<a href="{{ url_for('user_dashboard') }}">
<button class="back-btn">Back to Home</button>
</a>
</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
const map = L.map('map').setView([17.440894,78.444348],13);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
    attribution:'© OpenStreetMap contributors'
}).addTo(map);

let markers = {}, riderMarkers = {}, routes = {}, bounds = [];

function parseCoord(val){ const num=parseFloat(val); return isNaN(num)?null:num; }

async function drawRoute(start, end, id, color="blue"){
    if(!start||!end) return;
    const apiKey = "eyJvcmciOiI1YjNjZTM1OTc4NTExMTAwMDFjZjYyNDgiLCJpZCI6ImM1MjljOGZjNzkwYzQzZTc4ODU4NGM4MDczZjAyNjBmIiwiaCI6Im11cm11cjY0In0="; // replace with your ORS API key
    const url = `https://api.openrouteservice.org/v2/directions/driving-car?api_key=${apiKey}&start=${start[1]},${start[0]}&end=${end[1]},${end[0]}`;
    try{
        const res = await fetch(url);
        const data = await res.json();
        const coords = data.features[0].geometry.coordinates.map(c => [c[1], c[0]]);
        if(routes[id]){
            routes[id].setLatLngs(coords);
        }else{
            routes[id] = L.polyline(coords,{color:color,weight:5}).addTo(map);
        }
    }catch(err){console.log("Route error",err);}
}

async function loadOrders(){
    try{
        const res = await fetch("/get_customer_orders");
        const orders = await res.json();
        const tbody = document.getElementById("orders-tbody");
        tbody.innerHTML = "";
        bounds=[];

        Object.values(markers).forEach(m=>map.removeLayer(m));
        Object.values(riderMarkers).forEach(m=>map.removeLayer(m));
        Object.values(routes).forEach(r=>map.removeLayer(r));
        markers = {}; riderMarkers = {}; routes={};

        orders.forEach(order=>{
            // simulate is_otp_verified from status
            order.is_otp_verified = (order.status==='Delivered');

            // Table row
            tbody.innerHTML += `
<tr>
<td>${order.order_number}</td>
<td>${order.name}</td>
<td><img src="/static/${order.image}" class="product-img"></td>
<td>${order.quantity}</td>
<td>₹${order.price*order.quantity}</td>
<td><span class="status ${order.is_otp_verified?'delivered':order.status.toLowerCase()}">${order.is_otp_verified?'Delivered':order.status}</span></td>
<td><span class="status ${order.payment_status.toLowerCase()}">${order.payment_status}</span></td>
<td>${order.payment_status=='Refunded'?'₹'+(order.price*order.quantity):'-'}</td>
<td>${order.created_at}</td>
<td>${!order.is_otp_verified?`<a href="/track_order/${order.id}"><button class="track-btn">Track Order</button></a>`:'-'}</td>
</tr>
            `;

            if(order.is_otp_verified) return; // skip tracking for delivered

            const pickupLat=parseCoord(order.pickup_lat);
            const pickupLng=parseCoord(order.pickup_lng);
            const custLat=parseCoord(order.customer_lat);
            const custLng=parseCoord(order.customer_lng);

            if(pickupLat && pickupLng && !markers["pickup_"+order.id]){
                markers["pickup_"+order.id] = L.marker([pickupLat,pickupLng],{
                    icon:L.icon({iconUrl:"https://cdn-icons-png.flaticon.com/512/684/684908.png",iconSize:[30,30]})
                }).addTo(map).bindPopup("Store: "+(order.pickup_address||""));
            }
            if(custLat && custLng && !markers["cust_"+order.id]){
                markers["cust_"+order.id] = L.marker([custLat,custLng],{
                    icon:L.icon({iconUrl:"https://cdn-icons-png.flaticon.com/512/149/149071.png",iconSize:[30,30]})
                }).addTo(map).bindPopup("Customer: "+(order.customer_address||""));
            }

            if(pickupLat && pickupLng && custLat && custLng){
                drawRoute([pickupLat,pickupLng],[custLat,custLng],"store_customer_"+order.id,"blue");
            }

            if(pickupLat && pickupLng) bounds.push([pickupLat,pickupLng]);
            if(custLat && custLng) bounds.push([custLat,custLng]);
        });

        if(bounds.length>0) map.fitBounds(bounds,{padding:[50,50]});
    }catch(err){ console.error("Error loading orders:",err);}
}

async function updateRiders(){
    try{
        const res = await fetch("/get_rider_locations"); // should return [{id,name,lat,lng,rider_orders:[order_id,...]}]
        const data = await res.json();

        data.forEach(r=>{
            const lat=parseCoord(r.lat);
            const lng=parseCoord(r.lng);
            if(!lat||!lng) return;

            if(riderMarkers[r.id]){
                riderMarkers[r.id].setLatLng([lat,lng]);
            }else{
                riderMarkers[r.id] = L.marker([lat,lng],{
                    icon:L.icon({iconUrl:"https://cdn-icons-png.flaticon.com/512/149/149059.png",iconSize:[30,30]})
                }).addTo(map).bindPopup(r.name||"Rider");
            }

            r.rider_orders.forEach(o=>{
                o.is_otp_verified = (o.status==='Delivered'); // simulate
                if(o.is_otp_verified) return; // stop tracking delivered

                const pickupLat=parseCoord(o.pickup_lat);
                const pickupLng=parseCoord(o.pickup_lng);
                const custLat=parseCoord(o.customer_lat);
                const custLng=parseCoord(o.customer_lng);

                if(o.status==="Accepted" && pickupLat && pickupLng){
                    drawRoute([lat,lng],[pickupLat,pickupLng],"rider_store_"+o.id,"green");
                }
                if(o.status==="Picked" && custLat && custLng){
                    drawRoute([lat,lng],[custLat,custLng],"rider_customer_"+o.id,"orange");
                }
            });
        });
    }catch(err){ console.error("Error updating riders:",err);}
}

setInterval(loadOrders,5000);
setInterval(updateRiders,5000);
loadOrders();
updateRiders();
</script>
</body>
</html>