```html
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Rider Dashboard</title>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

<style>
#map{
height:500px;
width:100%;
margin-bottom:20px;
}
</style>

</head>

<body>

<div class="container mt-4">

<h2>Rider Dashboard</h2>

<div id="map"></div>

<table class="table table-bordered">
<thead>
<tr>
<th>Order</th>
<th>Product</th>
<th>Qty</th>
<th>Status</th>
</tr>
</thead>

<tbody>
{% for order in orders %}
<tr>
<td>{{order.order_number}}</td>
<td>{{order.product_name}}</td>
<td>{{order.quantity}}</td>
<td>{{order.rider_status}}</td>
</tr>
{% endfor %}
</tbody>

</table>

</div>

<script>

let map;
let riderMarker;
let markers = {};
let directionsService;

const orders = {{ orders|tojson }};

function initMap(){

map = new google.maps.Map(document.getElementById("map"),{
center:{lat:17.440894,lng:78.444348},
zoom:13
});

directionsService = new google.maps.DirectionsService();

loadOrders();

sendLocation();

setInterval(sendLocation,5000);

}

function loadOrders(){

orders.forEach(o=>{

let pickupLat = parseFloat(o.pickup_lat);
let pickupLng = parseFloat(o.pickup_lng);
let custLat = parseFloat(o.customer_lat);
let custLng = parseFloat(o.customer_lng);

if(pickupLat && pickupLng){

markers["pickup_"+o.id] = new google.maps.Marker({

position:{lat:pickupLat,lng:pickupLng},

map:map,

icon:{
url:"https://cdn-icons-png.flaticon.com/512/684/684908.png",
scaledSize:new google.maps.Size(30,30)
},

title:"Store"

});

}

if(custLat && custLng){

markers["cust_"+o.id] = new google.maps.Marker({

position:{lat:custLat,lng:custLng},

map:map,

icon:{
url:"https://cdn-icons-png.flaticon.com/512/149/149071.png",
scaledSize:new google.maps.Size(30,30)
},

title:"Customer"

});

}

drawRoute(
{lat:pickupLat,lng:pickupLng},
{lat:custLat,lng:custLng}
);

});

}

function drawRoute(start,end){

const renderer = new google.maps.DirectionsRenderer({

suppressMarkers:true,
polylineOptions:{strokeColor:"blue",strokeWeight:5}

});

renderer.setMap(map);

directionsService.route({

origin:start,
destination:end,
travelMode:"DRIVING"

},function(result,status){

if(status==="OK"){
renderer.setDirections(result);
}

});

}

function sendLocation(){

if(navigator.geolocation){

navigator.geolocation.getCurrentPosition(function(pos){

const lat = pos.coords.latitude;
const lng = pos.coords.longitude;

updateRiderMarker(lat,lng);

fetch("/update_rider_location",{

method:"POST",

headers:{"Content-Type":"application/json"},

body:JSON.stringify({lat,lng})

});

});

}

}

function updateRiderMarker(lat,lng){

const position = {lat:lat,lng:lng};

if(!riderMarker){

riderMarker = new google.maps.Marker({

position:position,

map:map,

icon:{
url:"https://cdn-icons-png.flaticon.com/512/1008/1008100.png",
scaledSize:new google.maps.Size(40,40)
},

title:"Rider"

});

map.setCenter(position);

}

else{

animateMarker(riderMarker,position);

}

}

function animateMarker(marker,newPos){

let start = marker.getPosition();

let frames = 30;

let latStep = (newPos.lat-start.lat())/frames;

let lngStep = (newPos.lng-start.lng())/frames;

let frame=0;

let move=setInterval(function(){

frame++;

let lat=start.lat()+latStep*frame;

let lng=start.lng()+lngStep*frame;

marker.setPosition({lat:lat,lng:lng});

if(frame>=frames){

clearInterval(move);

}

},30);

}

</script>

<script async
src="https://maps.googleapis.com/maps/api/js?key=AIzaSyBsIwRqB6od6FkkrmwFrB7lIhBbten2PZA&callback=initMap">
</script>

</body>
</html>
```
