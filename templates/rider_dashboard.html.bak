<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Rider Dashboard</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>

<style>
body{
margin:0;
font-family:Arial;
background:#0a0a0a;
color:#fff;
}

.header{
padding:15px;
display:flex;
justify-content:space-between;
background:#111;
border-bottom:1px solid #222;
}

.status-btn{
padding:8px 12px;
border:none;
border-radius:6px;
cursor:pointer;
}

.online{background:#22c55e;}
.offline{background:#ef4444;color:#fff;}

.container{
display:grid;
grid-template-columns:1fr 1fr;
gap:20px;
padding:20px;
}

#map{
height:500px;
border-radius:12px;
}

.card{
background:#111;
padding:12px;
margin-bottom:10px;
border-radius:10px;
border:1px solid #222;
}

.badge{
padding:4px 8px;
border-radius:6px;
font-size:12px;
}

.Assigned{background:#f59e0b;}
.Accepted{background:#3b82f6;}
.Picked{background:#a855f7;}
</style>
</head>

<body>

<div class="header">
<h2>🚴 Rider Dashboard</h2>

<div>
<a href="/rider/online"><button class="status-btn online">Go Online</button></a>
<a href="/rider/offline"><button class="status-btn offline">Go Offline</button></a>
</div>
</div>

<div class="container">

<div id="map"></div>

<div>

<h3>Orders</h3>

{% for order in orders %}
<div class="card">

<b>{{ order.order_number }}</b><br>
{{ order.product_name }} (x{{ order.quantity }})<br>
Customer: {{ order.customer_name }}<br>

<span class="badge {{ order.rider_status }}">
{{ order.rider_status }}
</span>

<br>

{% if order.rider_status == 'Assigned' %}
<a href="/accept_order/{{ order.id }}">
<button style="background:#3b82f6;color:#fff">Accept</button>
</a>
{% endif %}

{% if order.rider_status == 'Accepted' %}
<button onclick="pickupOrder({{ order.id }})">Pickup</button>
{% endif %}

{% if order.rider_status == 'Picked' %}
<a href="/verify_delivery/{{ order.id }}">
<button style="background:#22c55e">Verify OTP</button>
</a>
{% endif %}

</div>
{% endfor %}

</div>

</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
const orders = {{ orders | tojson }};
</script>

<script>

const map = L.map('map').setView([17.4, 78.4], 12);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19
}).addTo(map);

// 📍 Marker
function addMarker(latlng, text) {
    return L.marker(latlng).addTo(map).bindPopup(text);
}

// 🚀 OSRM REAL ROUTE
async function drawRoute(a, b, color) {
    try {
        const url = `https://router.project-osrm.org/route/v1/driving/${a[1]},${a[0]};${b[1]},${b[0]}?overview=full&geometries=geojson`;

        const res = await fetch(url);
        const data = await res.json();

        if (!data.routes || !data.routes[0]) return;

        const coords = data.routes[0].geometry.coordinates.map(c => [c[1], c[0]]);

        L.polyline(coords, {
            color: color,
            weight: 4
        }).addTo(map);

    } catch (e) {
        console.log(e);
    }
}

// 🚴 Pickup button
function pickupOrder(id){
    fetch("/pickup_order/" + id).then(()=>location.reload());
}

// 🧠 MAIN MAP LOGIC
function loadMap() {

    orders.forEach(order => {

        const pickup = [
            parseFloat(order.pickup_lat),
            parseFloat(order.pickup_lng)
        ];

        const customer = [
            parseFloat(order.customer_lat),
            parseFloat(order.customer_lng)
        ];

        // 📍 Always show markers
        addMarker(pickup, "🏪 Store");
        addMarker(customer, "🏠 Customer");

        // 🟡 ACCEPTED → Rider → Store
        if (order.rider_status === "Accepted" && order.rider_lat) {

            const rider = [
                parseFloat(order.rider_lat),
                parseFloat(order.rider_lng)
            ];

            addMarker(rider, "🚴 Rider");

            drawRoute(rider, pickup, "blue");
        }

        // 🔴 PICKED → Store → Customer
        if (order.rider_status === "Picked") {

            drawRoute(pickup, customer, "green");
        }

    });
}

// 🚀 CALL FUNCTION (IMPORTANT)
loadMap();

</script>

</body>
</html>