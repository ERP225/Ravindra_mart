<style>
.timeline {
display:flex;
gap:20px;
margin-top:20px;
}

.timeline div{
padding:10px 15px;
border-radius:6px;
background:#ccc;
}

.timeline .active{
background:green;
color:white;
}

</style>

<h2>Order Tracking</h2>

<p>Order ID: {{ order.order_number }}</p>
<p>Product: {{ order.name }}</p>

<img src="/static/{{ order.image }}" width="120">

<h3>Status: {{ order.status }}</h3>

<div class="timeline">

<div class="{% if order.status in ['Pending','Packed','Shipped','Out for Delivery','Delivered'] %}active{% endif %}">
Order Placed
</div>

<div class="{% if order.status in ['Packed','Shipped','Out for Delivery','Delivered'] %}active{% endif %}">
Packed
</div>

<div class="{% if order.status in ['Shipped','Out for Delivery','Delivered'] %}active{% endif %}">
Shipped
</div>

<div class="{% if order.status in ['Out for Delivery','Delivered'] %}active{% endif %}">
Out for Delivery
</div>

<div class="{% if order.status == 'Delivered' %}active{% endif %}">
Delivered
</div>

</div>