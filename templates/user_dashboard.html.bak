<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Ravi Mart - Shop</title>

<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Roboto',sans-serif;
}

body{
  background:#f4f6f9;
}

/* MAIN LAYOUT */

.container{
  display:flex;
}

/* SIDEBAR */

.sidebar{
  width:250px;
  background:#111827;
  color:white;
  min-height:100vh;
  padding:20px;
}

.profile{
  text-align:center;
  margin-bottom:25px;
}

.profile img{
  width:80px;
  height:80px;
  border-radius:50%;
  margin-bottom:10px;
}

.profile h4{
  font-size:18px;
}

.profile p{
  font-size:12px;
  color:#9ca3af;
}

/* MENU BUTTONS */

.menu button {
  display: block;
  width: 100%;
  text-align: left;
  padding: 12px;
  margin-bottom: 8px;
  border-radius: 8px;
  color: white;
  background: transparent;
  border: none;
  font-size: 14px;
  cursor: pointer;
  transition: 0.3s;
}

.menu button:hover{
  background:#f59e0b;
}

/* CATEGORY TITLE */

.cat-title{
  margin-top:20px;
  margin-bottom:10px;
  font-weight:bold;
  color:#facc15;
}

/* CONTENT AREA */

.content{
  flex:1;
}

/* NAVBAR */

.navbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:15px 25px;
  background:#1f2937;
  color:white;
}

.logo{
  font-size:20px;
  font-weight:bold;
  color:#facc15;
}

.navbar a{
  margin-left:20px;
  color:white;
}

.navbar a:hover{
  color:#facc15;
}

/* SEARCH */

.search-bar{
  display:flex;
  justify-content:center;
  margin:20px;
}

.search-bar input{
  width:300px;
  padding:10px;
  border-radius:20px 0 0 20px;
  border:1px solid #ccc;
}

.search-bar button{
  padding:10px 20px;
  border:none;
  background:#f59e0b;
  color:white;
  border-radius:0 20px 20px 0;
  cursor:pointer;
}

/* PRODUCTS */

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
  gap:20px;
  padding:20px;
}

.card{
  background:white;
  padding:15px;
  border-radius:12px;
  text-align:center;
  box-shadow:0 5px 15px rgba(0,0,0,0.1);
  transition:0.3s;
}

.card:hover{
  transform:translateY(-5px);
}

.card img{
  width:100%;
  height:170px;
  object-fit:cover;
  border-radius:10px;
}

.name{
  font-weight:600;
  margin:10px 0;
}

.price{
  color:#16a34a;
  font-weight:600;
}

.stock{
  font-size:13px;
  color:#6b7280;
  margin-bottom:10px;
}

.card button{
  padding:8px 14px;
  border:none;
  background:#f59e0b;
  color:white;
  border-radius:6px;
  cursor:pointer;
}

/* FLOATING CART */

#floating-cart{
  position:fixed;
  bottom:25px;
  right:25px;
  background:#f59e0b;
  color:white;
  padding:12px 16px;
  border-radius:50px;
  font-size:18px;
  cursor:pointer;
  box-shadow:0 5px 15px rgba(0,0,0,0.3);
  display:flex;
  gap:8px;
  align-items:center;
}

.cart-badge{
  background:red;
  padding:4px 8px;
  border-radius:50%;
  font-size:12px;
}

/* TOAST */

#toast{
  position:fixed;
  bottom:90px;
  right:25px;
  background:#333;
  color:white;
  padding:10px 18px;
  border-radius:8px;
  display:none;
}

</style>
</head>

<body>

<div class="container">

<!-- SIDEBAR -->

<div class="sidebar">

<div class="profile">
  <img src="{{ url_for('static', filename=user.profile_pic) }}">
  <h4>{{ session['user_name'] }}</h4>
  <p>Customer</p>
</div>

<!-- MAIN MENU -->

<div class="menu">
  <button onclick="location.href='/user_dashboard'"><i class="fa fa-home"></i> Home</button>
  <button onclick="location.href='/cart'"><i class="fa fa-shopping-cart"></i> Cart</button>
  <button onclick="location.href='/my_orders'"><i class="fa fa-box"></i> Orders</button>
  <button onclick="location.href='/profile'"><i class="fa fa-user"></i> Profile</button>
  <button onclick="location.href='/logout'"><i class="fa fa-sign-out"></i> Logout</button>
</div>

<div class="cat-title">Categories</div>

<!-- CATEGORY MENU -->

<div class="menu">
  <button onclick="location.href='/user_dashboard'">All Products</button>
  <button onclick="location.href='/user_dashboard?category=vegetables'">🥦 Vegetables</button>
  <button onclick="location.href='/user_dashboard?category=Fruits'">🍎 Fruits</button>
  <button onclick="location.href='/user_dashboard?category=dairy'">🥛 Dairy</button>
  <button onclick="location.href='/user_dashboard?category=snacks'">🍪 Snacks</button>
  <button onclick="location.href='/user_dashboard?category=drinks'">🥤 Drinks</button>
  <button onclick="location.href='/user_dashboard?category=groceries'">🛒 Groceries</button>
</div>

</div>

<!-- CONTENT -->

<div class="content">

<div class="navbar">
  <div class="logo">
    <i class="fas fa-store"></i> Ravi Mart
  </div>
</div>

<!-- SEARCH -->

<div class="search-bar">
  <form method="GET" action="/user_dashboard">
    <input type="text" name="search" placeholder="Search products..." value="{{ request.args.get('search','') }}">
    <button type="submit">Search</button>
  </form>
</div>

<!-- PRODUCT GRID -->

<div class="grid">

{% for product in products %}
<div class="card">
  <img src="{{ url_for('static', filename=product.image) }}">
  <div class="name">{{ product.name }}</div>
  <div class="price">₹{{ product.price }}</div>
  <div class="stock" data-stock="{{ product.quantity }}">
    {% if product.quantity>0 %}
      In Stock: {{ product.quantity }}
    {% else %}
      Out of Stock
    {% endif %}
  </div>

  {% if product.quantity>0 %}
  <form action="/add_to_cart/{{ product.id }}" method="POST" class="add-to-cart-form">
    <input type="number" name="qty" value="1" min="1" max="{{ product.quantity }}" style="width:60px;margin-bottom:10px;">
    <br>
    <button type="submit">Add to Cart</button>
  </form>
  {% else %}
    <button disabled>Out of Stock</button>
  {% endif %}
</div>
{% endfor %}

</div>

</div>

</div>

<!-- FLOATING CART -->

<div id="floating-cart" onclick="window.location.href='/cart'">
  <i class="fa fa-shopping-cart"></i>
  <span class="cart-badge">{{ cart_count }}</span>
</div>

<!-- TOAST -->

<div id="toast">Item added to cart</div>

<script>
document.querySelectorAll(".add-to-cart-form").forEach(form=>{
  form.addEventListener("submit",function(e){
    e.preventDefault()
    let url=this.action
    let formData=new FormData(this)
    fetch(url,{method:"POST",body:formData})
    .then(res=>res.json())
    .then(data=>{
      if(data.success){
        document.querySelectorAll(".cart-badge").forEach(b=>{
          b.textContent=data.cart_count
        })
        let toast=document.getElementById("toast")
        toast.style.display="block"
        setTimeout(()=>toast.style.display="none",1500)
      }else{
        alert(data.error)
      }
    })
  })
})
</script>

</body>
</html>